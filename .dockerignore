# ── Training artefacts (large, not needed in container) ───────────────────────
results of training road/
results of road inpainting/
results of training landcover/
results of training building (masachusses dataset)/
# NOTE: *.pth / *.pt / *.ckpt are intentionally NOT excluded here.
#       The model weights (road_model_best.pth, landcover_best.pth,
#       building_model_best.pth) must be copied into /app/ by COPY . .
#       so the server can load them at startup.

# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Git ────────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── IDE / OS ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Jupyter ────────────────────────────────────────────────────────────────────
*.ipynb
.ipynb_checkpoints/

# ── Temporary results (generated at runtime) ──────────────────────────────────
results/
/tmp/
